# ============================================================
# ULTRANOS — .env.example
# Copy to .env and fill in real values.
# Run `node scripts/generate-secrets.mjs` for JWT secrets.
# ============================================================

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

GEMINI_API_KEY=your_gemini_api_key_here

# Generated by: node scripts/generate-secrets.mjs
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET

CORS_ORIGIN=http://localhost:3001
