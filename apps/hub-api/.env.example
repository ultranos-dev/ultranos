# =============================================================================
# Hub API Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_JWK={"kty":"RSA","n":"...","e":"AQAB"}

# --- Field-Level Encryption (Story 7.3) ---
# Two separate 256-bit keys in hex format (64 hex characters each).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# FIELD_ENCRYPTION_KEY: AES-256-GCM key for encrypting/decrypting PHI columns
#   (diagnosis, reason_code, dosage_instruction, interaction_override, etc.)
#
# FIELD_ENCRYPTION_HMAC_KEY: HMAC-SHA256 key for blind index generation
#   (national_id lookups without decrypting stored values)
#
# IMPORTANT:
#   - These keys MUST be different from each other.
#   - Store in Supabase Secrets (supabase secrets set) or cloud secret manager.
#   - Losing these keys means permanent loss of all encrypted PHI data.
#   - Key rotation: encrypted values use "v1:" prefix to support future rotation.
#   - Back up keys securely in a separate system from the database.
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_HMAC_KEY=
